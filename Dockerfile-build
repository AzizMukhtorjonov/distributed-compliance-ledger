################################################################################
# Builds dcld application for further use on nodes in DCL pool in docker.
# The resulting image is used only for getting the build artifact from
# a container based on it. Containers based on this image are never run.
################################################################################
FROM ubuntu:20.04 AS builder

ARG GO_VERSION
ENV GO_VERSION=1.20

RUN apt-get update
RUN apt-get install -y wget git gcc make

RUN ARCH=$(dpkg --print-architecture); \
    if [ "$ARCH" = "amd64" ]; then GO_ARCH="linux-amd64"; \
    elif [ "$ARCH" = "arm64" ]; then GO_ARCH="linux-arm64"; \
    else echo "Unsupported architecture: $ARCH"; exit 1; fi; \
    wget -P /tmp "https://dl.google.com/go/go${GO_VERSION}.${GO_ARCH}.tar.gz"; \
    tar -C /usr/local -xzf "/tmp/go${GO_VERSION}.${GO_ARCH}.tar.gz"; \
    rm "/tmp/go${GO_VERSION}.${GO_ARCH}.tar.gz"; \
    echo "export GOARCH=${ARCH}" >> /etc/profile

ENV GOPATH=/go
ENV PATH=$GOPATH/bin:/usr/local/go/bin:$PATH
RUN mkdir -p "$GOPATH/src" "$GOPATH/bin" && chmod -R 777 "$GOPATH"

WORKDIR /go/src/dc-ledger
COPY app ./app/
COPY cmd ./cmd/
COPY testutil ./testutil/
COPY utils ./utils/
COPY x ./x/
COPY types ./types/
COPY go.mod go.sum Makefile ./
COPY docs/docs.go ./docs/
COPY docs/static ./docs/static/

ARG DCL_VERSION
ARG DCL_COMMIT
ARG GOCOVER
ENV GOCOVER=${GOCOVER}
RUN LEDGER_ENABLED=false make
